---
const currentYear = new Date().getFullYear();
const yearVars = JSON.stringify({ year: currentYear });
---

<footer>
	<p>
		<span data-i18n="footer.copyright" data-i18n-vars={yearVars}>&copy; {currentYear} Agustín Burgos</span>
		<span> · <a href="https://www.webxpert.com.ar" target="_blank" rel="noopener noreferrer">WebXpert</a></span>
	</p>
</footer>
<style>
	footer {
		margin-top: auto;
		padding: 3rem 2rem;
		text-align: center;
		color: var(--gray-400);
		font-size: var(--text-sm);
	}

	footer a {
		color: var(--gray-400);
		text-decoration: none;
		display: inline-block;
		transition: transform 0.2s ease;
	}

	footer a:hover {
		transform: scale(1.08);
	}

	@media (min-width: 50em) {
		footer {
			padding: 2.5rem 5rem;
		}
	}
</style>
