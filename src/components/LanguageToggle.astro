---

---

<language-toggle>
	<button aria-label="Switch language">
		<span class="lang-label en active">EN</span>
		<span class="separator">|</span>
		<span class="lang-label es">ES</span>
	</button>
</language-toggle>

<style>
	button {
		display: flex;
		align-items: center;
		gap: 0.25rem;
		border: 0;
		border-radius: 999rem;
		padding: 0.375rem 0.625rem;
		background-color: var(--gray-999);
		box-shadow: inset 0 0 0 1px var(--accent-overlay);
		cursor: pointer;
		font-family: var(--font-brand);
		font-size: 0.8rem;
		font-weight: 600;
		color: var(--accent-overlay);
		line-height: 1;
	}

	.lang-label {
		padding: 0.15rem 0.3rem;
		border-radius: 999rem;
		transition:
			background-color var(--theme-transition),
			color var(--theme-transition);
	}

	.lang-label.active {
		background-color: var(--accent-regular);
		color: var(--accent-text-over);
	}

	.separator {
		opacity: 0.3;
	}

	@media (prefers-reduced-motion: no-preference) {
		.lang-label {
			transition:
				background-color var(--theme-transition),
				color var(--theme-transition);
		}
	}
</style>

<script>
	class LanguageToggle extends HTMLElement {
		constructor() {
			super();
			const button = this.querySelector('button')!;
			const enLabel = this.querySelector('.lang-label.en')!;
			const esLabel = this.querySelector('.lang-label.es')!;

			const setLang = (lang: string, dispatch = false) => {
				document.documentElement.setAttribute('data-lang', lang);
				enLabel.classList.toggle('active', lang === 'en');
				esLabel.classList.toggle('active', lang === 'es');
				button.setAttribute(
					'aria-label',
					lang === 'en' ? 'Switch to Spanish' : 'Cambiar a Inglés',
				);
				if (dispatch) {
					window.dispatchEvent(new CustomEvent('langchange', { detail: { lang } }));
				}
			};

			// Get saved preference or default — initialize without dispatching
			const savedLang = localStorage.getItem('lang') || 'en';
			setLang(savedLang, false);

			button.addEventListener('click', () => {
				const current = document.documentElement.getAttribute('data-lang') || 'en';
				const next = current === 'en' ? 'es' : 'en';
				setLang(next, true);
				localStorage.setItem('lang', next);
			});
		}
	}
	customElements.define('language-toggle', LanguageToggle);
</script>
